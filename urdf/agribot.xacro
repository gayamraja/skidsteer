<?xml version="1.0"?>
<robot name="agribot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Materials -->
  <material name="grey"><color rgba="0.5 0.5 0.5 1.0"/></material>
  <material name="black"><color rgba="0.1 0.1 0.1 1.0"/></material>

  <!-- Base Link: High-clearance chassis at 600mm -->
  <!-- High-clearance agricultural design: 1.0m x 0.5m frame at 0.6m height -->
  <!-- This creates significant clearance above 405mm tires, matching workshop photo -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.6" rpy="0 0 0"/> 
      <geometry>
        <box size="1.0 0.5 0.04"/> 
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.6" rpy="0 0 0"/>
      <geometry>
        <box size="1.0 0.5 0.04"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="70.0"/>
      <origin xyz="0 0 0.6" rpy="0 0 0"/>
      <inertia ixx="2.0" ixy="0" ixz="0" iyy="3.0" iyz="0" izz="3.0"/>
    </inertial>
  </link>

  <!-- V-Leg Macro: Creates leg and wheel assembly -->
  <!-- High-clearance: Longer, more vertical legs to reach 0.6m chassis height -->
  <!-- Corrected dimensions: 81cm (0.81m) wheelbase, 87cm (0.87m) track -->
  <xacro:macro name="v_leg" params="prefix x_reflect y_reflect">
    <!-- Leg Link: Longer legs (0.55m) with more vertical angle for high clearance -->
    <link name="${prefix}_leg">
      <visual>
        <origin xyz="0 0 -0.2" rpy="0 ${x_reflect * 0.3} 0"/>
        <geometry><box size="0.05 0.05 0.55"/></geometry>
        <material name="grey"/>
      </visual>
      <collision>
        <origin xyz="0 0 -0.2" rpy="0 ${x_reflect * 0.3} 0"/>
        <geometry><box size="0.05 0.05 0.55"/></geometry>
      </collision>
      <inertial>
        <mass value="3.5"/>
        <origin xyz="0 0 -0.2"/>
        <inertia ixx="0.025" ixy="0" ixz="0" iyy="0.025" iyz="0" izz="0.025"/>
      </inertial>
    </link>

    <!-- Fixed joint connecting leg to base at chassis corners -->
    <joint name="${prefix}_leg_joint" type="fixed">
      <parent link="base_link"/>
      <child link="${prefix}_leg"/>
      <origin xyz="${x_reflect*0.45} ${y_reflect*0.25} 0.6" rpy="0 0 0"/>
    </joint>

    <!-- Wheel Link: 4.00-8 tire (405mm diameter, 0.2025m radius) -->
    <link name="${prefix}_wheel">
      <visual>
        <geometry><cylinder radius="0.2025" length="0.12"/></geometry>
        <material name="black"/>
      </visual>
      <collision>
        <geometry><cylinder radius="0.2025" length="0.12"/></geometry>
      </collision>
      <inertial>
        <mass value="8.0"/>
        <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.15"/>
      </inertial>
    </link>

    <!-- Jackshaft Link: 36T sprocket on middle jackshaft (two-stage chain drive) -->
    <!-- 16T (Gearbox) → 36T (Jackshaft) → 16T (Wheel) = 2.25:1 chain reduction -->
    <!-- Jackshaft positioned in middle of leg to preserve 0.6m ground clearance -->
    <link name="${prefix}_jackshaft">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.08" length="0.06"/>  <!-- 36T sprocket ~16cm diameter -->
        </geometry>
        <material name="grey"/>
      </visual>
      <collision>
        <geometry>
          <cylinder radius="0.08" length="0.06"/>
        </geometry>
      </collision>
      <inertial>
        <!-- Rotating mass of jackshaft + 36T sprocket acts as flywheel -->
        <!-- Adds rotational inertia - robot won't stop instantly when motor stops -->
        <mass value="2.5"/>  <!-- Jackshaft + large sprocket weight -->
        <inertia ixx="0.02" ixy="0" ixz="0" iyy="0.02" iyz="0" izz="0.02"/>
      </inertial>
    </link>

    <!-- Jackshaft joint: Rotating element in middle of leg (simulates 16T→36T chain stage) -->
    <joint name="${prefix}_jackshaft_joint" type="continuous">
      <parent link="${prefix}_leg"/>
      <child link="${prefix}_jackshaft"/>
      <!-- Positioned in middle of leg to keep 36T sprocket protected and high (preserves clearance) -->
      <origin xyz="${x_reflect*0.02} ${y_reflect*0.1} -0.15" rpy="${pi/2} 0 0"/>
      <axis xyz="0 0 1"/>
      <limit effort="300" velocity="10.0"/>
      <!-- First chain stage damping: 16T→36T (2.25:1) - higher damping from larger sprocket -->
      <dynamics damping="75.0" friction="15.0"/>
    </joint>

    <!-- Continuous joint for wheel rotation -->
    <!-- Wheel offset: 0.25m leg attachment + 0.185m wheel offset = 0.435m (half of 0.87m track) -->
    <!-- Z offset: -0.3975m to place wheel at ground level (0.6m chassis - 0.2025m radius - 0.3975m = 0.0m) -->
    <!-- Total reduction: 22.5:1 (10:1 gearbox + 2.25:1 chain: 16T→36T=2.25:1, 16T→16T=1:1) -->
    <!-- Note: Wheel is directly attached to leg for proper ground contact, but driven via chain from jackshaft -->
    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="${prefix}_leg"/>  <!-- Wheel attached to leg for ground contact -->
      <child link="${prefix}_wheel"/>
      <origin xyz="${x_reflect*0.06} ${y_reflect*0.185} -0.3975" rpy="${-pi/2} 0 0"/>
      <axis xyz="0 0 1"/>
      <!-- Max effort accounts for 22.5:1 reduction: 300Nm * 22.5 = 6750Nm at wheel -->
      <!-- But we cap at 300Nm to match gearbox rating -->
      <limit effort="300" velocity="10.0"/>
      <!-- Second chain stage: 16T to 16T (1:1) - includes jackshaft flywheel inertia effect -->
      <!-- Dual-chain system: increased backlash and damping from two chains -->
      <dynamics damping="50.0" friction="10.0"/>
    </joint>
    
    <!-- Gazebo friction parameters for skid-steer -->
    <!-- Gearbox friction acts as natural brake when power is cut -->
    <gazebo reference="${prefix}_wheel">
      <mu1>1.1</mu1>
      <mu2>0.5</mu2>
      <kp>1000000.0</kp>
      <kd>10.0</kd>
      <!-- Gearbox damping to simulate 10:1 gearbox internal resistance -->
      <minDepth>0.001</minDepth>
      <maxVel>1.0</maxVel>
    </gazebo>
    
    <!-- Gearbox joint damping (simulates 10:1 gearbox backlash and friction) -->
    <gazebo reference="${prefix}_wheel_joint">
      <implicitSpringDamper>true</implicitSpringDamper>
      <stopCfm>0.1</stopCfm>
      <stopErp>0.2</stopErp>
      <fudgeFactor>0.5</fudgeFactor>
    </gazebo>
  </xacro:macro>

  <!-- Instantiate 4 V-legs: front_left, front_right, rear_left, rear_right -->
  <xacro:v_leg prefix="front_left"  x_reflect="1"  y_reflect="1" />
  <xacro:v_leg prefix="front_right" x_reflect="1"  y_reflect="-1" />
  <xacro:v_leg prefix="rear_left"   x_reflect="-1" y_reflect="1" />
  <xacro:v_leg prefix="rear_right"  x_reflect="-1" y_reflect="-1" />

  <!-- Gazebo plugin for skid steer control -->
  <!-- Using diff_drive plugin with front wheels as primary control -->
  <!-- Rear wheels will follow via physics coupling -->
  <gazebo>
    <plugin name="differential_drive_controller" filename="libgazebo_ros_diff_drive.so">
      <update_rate>100</update_rate>
      <robotNamespace>/</robotNamespace>
      <left_joint>front_left_wheel_joint</left_joint>
      <right_joint>front_right_wheel_joint</right_joint>
      <wheel_separation>0.87</wheel_separation>
      <wheel_diameter>0.405</wheel_diameter>
      <max_wheel_torque>300</max_wheel_torque>
      <command_topic>cmd_vel</command_topic>
      <odometry_topic>odom</odometry_topic>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_link</robot_base_frame>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
    </plugin>
  </gazebo>
  
  <!-- Sync rear wheels with front wheels for proper skid steer -->
  <gazebo reference="rear_left_wheel_joint">
    <implicitSpringDamper>true</implicitSpringDamper>
  </gazebo>
  <gazebo reference="rear_right_wheel_joint">
    <implicitSpringDamper>true</implicitSpringDamper>
  </gazebo>

  <!-- IMU plugin for orientation monitoring (needed for safety tests) -->
  <gazebo reference="base_link">
    <sensor name="imu_sensor" type="imu">
      <plugin filename="libgazebo_ros_imu_sensor.so" name="imu_plugin">
        <ros>
          <namespace>/</namespace>
          <remapping>~/out:=imu/data</remapping>
        </ros>
        <update_rate>100</update_rate>
        <imu>
          <angular_velocity>
            <x>
              <noise type="gaussian">
                <mean>0.0</mean>
                <stddev>0.0002</stddev>
              </noise>
            </x>
            <y>
              <noise type="gaussian">
                <mean>0.0</mean>
                <stddev>0.0002</stddev>
              </noise>
            </y>
            <z>
              <noise type="gaussian">
                <mean>0.0</mean>
                <stddev>0.0002</stddev>
              </noise>
            </z>
          </angular_velocity>
          <linear_acceleration>
            <x>
              <noise type="gaussian">
                <mean>0.0</mean>
                <stddev>0.01</stddev>
              </noise>
            </x>
            <y>
              <noise type="gaussian">
                <mean>0.0</mean>
                <stddev>0.01</stddev>
              </noise>
            </y>
            <z>
              <noise type="gaussian">
                <mean>0.0</mean>
                <stddev>0.01</stddev>
              </noise>
            </z>
          </linear_acceleration>
        </imu>
      </plugin>
    </sensor>
  </gazebo>

</robot>
